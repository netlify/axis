{
  "scenarios": "./scenarios",
  "agents": ["gemini"],
  "mcp_servers": {
    "netlify": {
      "type": "http",
      "url": "https://mcp.netlify.com",
      "headers": { "Authorization": "Bearer test-token" }
    },
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/tmp"]
    }
  }
}
