---
import "../styles/docs.css";

interface Props {
  title: string;
  active: "overview" | "quickstart" | "scoring" | "scenarios" | "running" | "reports" | "cli" | "configuration";
  landing?: boolean;
}

const { title, active, landing = false } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} - AXIS Docs</title>
    <meta name="description" content="Documentation for AXIS, the Agent eXperience Index Score synthetic testing framework for AI agents." />
  </head>
  <body class:list={{ "body-landing": landing }}>
    <header class="site-header">
      <a href="/" class="site-logo" aria-label="AXIS home">
        <span class="site-logo-mark"><span class="logo-ax">AX</span><span class="logo-i">I</span>S</span>
      </a>
      <div class="site-header-links">
        {landing && (
          <a href="/quickstart" class="site-header-doc">Docs</a>
        )}
        <a href="https://github.com/netlify/axis">GitHub</a>
        <a href="https://www.npmjs.com/package/@netlify/axis">npm</a>
      </div>
      {!landing && (
        <button class="mobile-menu-btn" id="menu-btn" aria-label="Toggle navigation">&#9776;</button>
      )}
    </header>

    {landing ? (
      <main class="landing-main">
        <slot />
        <footer class="site-footer site-footer-landing">
          AXIS is OSS maintained by <a href="https://www.netlify.com">Netlify</a> and the open source contributors.
        </footer>
      </main>
    ) : (
      <div class="site-shell">
        <div class="sidebar-backdrop" id="sidebar-backdrop"></div>
        <aside class="sidebar" id="sidebar">
          <nav class="sidebar-nav">
            <div class="sidebar-section-label">Getting Started</div>
            <a href="/" class:list={["sidebar-link", { active: active === "overview" }]}>Home</a>
            <a href="/quickstart" class:list={["sidebar-link", { active: active === "quickstart" }]}>Quick Start</a>
            <div class="sidebar-section-label">Core Concepts</div>
            <a href="/scoring" class:list={["sidebar-link", { active: active === "scoring" }]}>Scoring Framework</a>
            <a href="/scenarios" class:list={["sidebar-link", { active: active === "scenarios" }]}>Writing Scenarios</a>
            <div class="sidebar-section-label">Running Tests</div>
            <a href="/running" class:list={["sidebar-link", { active: active === "running" }]}>Execution & Agents</a>
            <a href="/reports" class:list={["sidebar-link", { active: active === "reports" }]}>Reports & Baselines</a>
            <div class="sidebar-section-label">Reference</div>
            <a href="/cli" class:list={["sidebar-link", { active: active === "cli" }]}>CLI</a>
            <a href="/configuration" class:list={["sidebar-link", { active: active === "configuration" }]}>Configuration</a>
          </nav>
        </aside>

        <main class="main-content">
          <slot />
          <footer class="site-footer">
            AXIS is OSS maintained by <a href="https://www.netlify.com">Netlify</a> and the open source contributors.
          </footer>
        </main>
      </div>
    )}

    {!landing && (
      <script is:inline>
        const btn = document.getElementById("menu-btn");
        const sidebar = document.getElementById("sidebar");
        const backdrop = document.getElementById("sidebar-backdrop");

        function toggle() {
          sidebar.classList.toggle("open");
          backdrop.classList.toggle("open");
        }

        btn.addEventListener("click", toggle);
        backdrop.addEventListener("click", toggle);

        // Auto-generate heading IDs and anchor links
        document.querySelectorAll(".main-content h2, .main-content h3, .main-content h4").forEach(function (heading) {
          if (!heading.id) {
            heading.id = heading.textContent.trim().toLowerCase()
              .replace(/[^a-z0-9]+/g, "-")
              .replace(/(^-|-$)/g, "");
          }
          var link = document.createElement("a");
          link.href = "#" + heading.id;
          link.className = "heading-anchor";
          link.setAttribute("aria-label", "Link to " + heading.textContent.trim());
          link.textContent = "#";
          heading.appendChild(link);
        });
      </script>
    )}
  </body>
</html>
