              <div class="lp-agent-logo"><img src="/agents/fastagent.png" class="lp-agent-icon" alt="">fast-agent</div>
              <div class="lp-agent-logo"><img src="/agents/openhands.png" class="lp-agent-icon" alt="">OpenHands</div>
              <div class="lp-agent-logo"><img src="/agents/qwen.svg" class="lp-agent-icon" alt="">Qwen Code</div>
              <div class="lp-agent-logo"><img src="/agents/kimi.svg" class="lp-agent-icon" alt="">Kimi</div>
              <div class="lp-agent-logo"><img src="/agents/mistral.svg" class="lp-agent-icon" alt="">Mistral Vibe</div>
              <div class="lp-agent-logo"><img src="/agents/blackbox.png" class="lp-agent-icon" alt="">Blackbox</div>
              <div class="lp-agent-logo"><img src="/agents/stakpak.png" class="lp-agent-icon" alt="">Stakpak</div>
              <div class="lp-agent-logo"><img src="/agents/poolside.svg" class="lp-agent-icon" alt="">Poolside</div>

              <div class="lp-agent-logo"><img src="/agents/cursor.png" class="lp-agent-icon" alt="">Cursor</div>
              <div class="lp-agent-logo"><img src="/agents/auggie.png" class="lp-agent-icon" alt="">Auggie</div>
              <div class="lp-agent-logo"><img src="/agents/factorydroid.png" class="lp-agent-icon" alt="">Factory Droid</div>
              <div class="lp-agent-logo"><img src="/agents/qoder.svg" class="lp-agent-icon" alt="">Qoder</div>
              <div class="lp-agent-logo"><img src="/agents/cline.svg" class="lp-agent-icon" alt="">Cline</div>
              <div class="lp-agent-logo"><img src="/agents/kilo.svg" class="lp-agent-icon" alt="">Kilo</div>
              <div class="lp-agent-logo"><img src="/agents/copilot.png" class="lp-agent-icon" alt="">Copilot</div>
              <!-- duplicate for seamless loop -->
              <div class="lp-agent-logo"><img src="/agents/claude.svg" class="lp-agent-icon" alt="">Claude Code</div>
              <div class="lp-agent-logo"><img src="/agents/codex.svg" class="lp-agent-icon" alt="">Codex</div>

              <div class="lp-agent-logo"><img src="/agents/gemini.svg" class="lp-agent-icon" alt="">Gemini</div>
              <div class="lp-agent-logo"><img src="/agents/kiro.png" class="lp-agent-icon" alt="">Kiro</div>
              <div class="lp-agent-logo"><img src="/agents/goose.svg" class="lp-agent-icon" alt="">Goose</div>
              <div class="lp-agent-logo"><img src="/agents/opencode.svg" class="lp-agent-icon" alt="">opencode</div>
              <div class="lp-agent-logo"><img src="/agents/fastagent.png" class="lp-agent-icon" alt="">fast-agent</div>
              <div class="lp-agent-logo"><img src="/agents/openhands.png" class="lp-agent-icon" alt="">OpenHands</div>
              <div class="lp-agent-logo"><img src="/agents/qwen.svg" class="lp-agent-icon" alt="">Qwen Code</div>
              <div class="lp-agent-logo"><img src="/agents/kimi.svg" class="lp-agent-icon" alt="">Kimi</div>
              <div class="lp-agent-logo"><img src="/agents/mistral.svg" class="lp-agent-icon" alt="">Mistral Vibe</div>
              <div class="lp-agent-logo"><img src="/agents/blackbox.png" class="lp-agent-icon" alt="">Blackbox</div>
              <div class="lp-agent-logo"><img src="/agents/stakpak.png" class="lp-agent-icon" alt="">Stakpak</div>
              <div class="lp-agent-logo"><img src="/agents/poolside.svg" class="lp-agent-icon" alt="">Poolside</div>

              <div class="lp-agent-logo"><img src="/agents/cursor.png" class="lp-agent-icon" alt="">Cursor</div>
              <div class="lp-agent-logo"><img src="/agents/auggie.png" class="lp-agent-icon" alt="">Auggie</div>
              <div class="lp-agent-logo"><img src="/agents/factorydroid.png" class="lp-agent-icon" alt="">Factory Droid</div>
