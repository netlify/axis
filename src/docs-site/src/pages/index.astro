---
import DocsLayout from "../layouts/DocsLayout.astro";
import DimensionCards from "../components/DimensionCards";

// Figma asset URLs (valid for 7 days from design export — replace with permanent assets)
const imgUsedByLogos = "https://www.figma.com/api/mcp/asset/b2c48c87-848e-4c58-b98d-1ac5a8fdeeae";
const imgNetlifyLogo = "https://www.figma.com/api/mcp/asset/ad7cac49-b844-4e32-a892-d84e57381563";
---

<DocsLayout
  title="AXIS — Agent Experience Index Score"
  description="AXIS is open source tooling and a scoring framework to measure how well services work for AI agents. Run real scenarios, get a 0–100 score, and fix what's slowing agents down."
  active="overview"
  landing={true}
>
  <div class="lp">

    <!-- ── Hero ─────────────────────────────────────── -->
    <section class="lp-hero">
      <div class="lp-hero-inner">
        <!-- Top: badge + headline (full left width) -->
        <div class="lp-hero-top">
          <div class="lp-badge">
            <span class="lp-badge-dot" aria-hidden="true"></span>
            <span class="lp-badge-label">OPEN SOURCE</span>
            <span class="lp-badge-sep" aria-hidden="true">•</span>
            <span>Created by Netlify</span>
          </div>

          <h1 class="lp-headline">
            Stop guessing if agents<br />
            can use your service
          </h1>
        </div>

        <!-- Bottom: lead row (paragraph + card) then CTA -->
        <div class="lp-hero-bottom">
          <div class="lp-hero-lead-row">
          <p class="lp-lead">
            Think Lighthouse, but for agent experience. AXIS — the Agent Experience Index Score — is open source tooling and a scoring framework to measure how well your APIs, services, and project structure work for AI agents.
          </p>

          <!-- Right: numbered steps card -->
          <div class="lp-steps-wrap">
          <div class="lp-steps-card">
          <div class="lp-step">
            <div class="lp-step-left">
              <span class="lp-step-num" aria-hidden="true">1</span>
              <div class="lp-step-content">
                <span class="lp-step-label" aria-hidden="true">INSTALL</span>
                <code class="lp-step-cmd"><span class="lp-step-prompt" aria-hidden="true">$ </span>npm i -g @netlify/axis</code>
              </div>
            </div>
            <button class="lp-step-copy" type="button" data-copy="npm i -g @netlify/axis" aria-label="Copy install command">
              <svg width="12" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                <path d="M4 1.5A1.5 1.5 0 0 1 5.5 0h7A1.5 1.5 0 0 1 14 1.5v9a1.5 1.5 0 0 1-1.5 1.5H10v-1h2.5a.5.5 0 0 0 .5-.5v-9a.5.5 0 0 0-.5-.5h-7a.5.5 0 0 0-.5.5V4H4V1.5Z"/>
                <path d="M2 5.5A1.5 1.5 0 0 1 3.5 4h7A1.5 1.5 0 0 1 12 5.5v9a1.5 1.5 0 0 1-1.5 1.5h-7A1.5 1.5 0 0 1 2 14.5v-9Zm1.5-.5a.5.5 0 0 0-.5.5v9a.5.5 0 0 0 .5.5h7a.5.5 0 0 0 .5-.5v-9a.5.5 0 0 0-.5-.5h-7Z"/>
              </svg>
            </button>
          </div>
          <div class="lp-step-divider" aria-hidden="true"></div>
          <div class="lp-step">
            <div class="lp-step-left">
              <span class="lp-step-num" aria-hidden="true">2</span>
              <div class="lp-step-content">
                <span class="lp-step-label" aria-hidden="true">SET UP</span>
                <code class="lp-step-cmd"><span class="lp-step-prompt" aria-hidden="true">$ </span>axis init</code>
              </div>
            </div>
            <button class="lp-step-copy" type="button" data-copy="axis init" aria-label="Copy set up command">
              <svg width="12" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                <path d="M4 1.5A1.5 1.5 0 0 1 5.5 0h7A1.5 1.5 0 0 1 14 1.5v9a1.5 1.5 0 0 1-1.5 1.5H10v-1h2.5a.5.5 0 0 0 .5-.5v-9a.5.5 0 0 0-.5-.5h-7a.5.5 0 0 0-.5.5V4H4V1.5Z"/>
                <path d="M2 5.5A1.5 1.5 0 0 1 3.5 4h7A1.5 1.5 0 0 1 12 5.5v9a1.5 1.5 0 0 1-1.5 1.5h-7A1.5 1.5 0 0 1 2 14.5v-9Zm1.5-.5a.5.5 0 0 0-.5.5v9a.5.5 0 0 0 .5.5h7a.5.5 0 0 0 .5-.5v-9a.5.5 0 0 0-.5-.5h-7Z"/>
              </svg>
            </button>
          </div>
          <div class="lp-step-divider" aria-hidden="true"></div>
          <div class="lp-step">
            <div class="lp-step-left">
              <span class="lp-step-num" aria-hidden="true">3</span>
              <div class="lp-step-content">
                <span class="lp-step-label" aria-hidden="true">RUN</span>
                <code class="lp-step-cmd"><span class="lp-step-prompt" aria-hidden="true">$ </span>axis run</code>
              </div>
            </div>
            <button class="lp-step-copy" type="button" data-copy="axis run" aria-label="Copy run command">
              <svg width="12" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                <path d="M4 1.5A1.5 1.5 0 0 1 5.5 0h7A1.5 1.5 0 0 1 14 1.5v9a1.5 1.5 0 0 1-1.5 1.5H10v-1h2.5a.5.5 0 0 0 .5-.5v-9a.5.5 0 0 0-.5-.5h-7a.5.5 0 0 0-.5.5V4H4V1.5Z"/>
                <path d="M2 5.5A1.5 1.5 0 0 1 3.5 4h7A1.5 1.5 0 0 1 12 5.5v9a1.5 1.5 0 0 1-1.5 1.5h-7A1.5 1.5 0 0 1 2 14.5v-9Zm1.5-.5a.5.5 0 0 0-.5.5v9a.5.5 0 0 0 .5.5h7a.5.5 0 0 0 .5-.5v-9a.5.5 0 0 0-.5-.5h-7Z"/>
              </svg>
            </button>
          </div>
          </div><!-- /.lp-steps-card -->
          </div><!-- /.lp-steps-wrap -->
          </div><!-- /.lp-hero-lead-row -->

          <div class="lp-hero-cta">
            <a href="/quickstart" class="lp-btn-primary">Get started <span class="btn-arrow">→</span></a>
            <a href="https://github.com/netlify/axis" class="lp-btn-ghost" target="_blank" rel="noopener">
              View on
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="19.75" viewBox="0 0 21 21" fill="none" aria-hidden="true" style="width:20px;height:19.75px;aspect-ratio:20/19.75;flex-shrink:0">
                <path d="M9.48986 6.00024C9.19595 5.54029 8.79093 5.16178 8.31217 4.89962C7.8334 4.63747 7.29633 4.50012 6.75049 4.50024C6.50769 4.92003 6.36206 5.38889 6.32431 5.87236C6.28657 6.35583 6.35766 6.84161 6.53236 7.29399C6.19033 7.79767 6.00524 8.39143 6.00049 9.00024V9.50024C6.00049 10.2959 6.31656 11.059 6.87917 11.6216C7.44178 12.1842 8.20484 12.5002 9.00049 12.5002H12.0005C12.7961 12.5002 13.5592 12.1842 14.1218 11.6216C14.6844 11.059 15.0005 10.2959 15.0005 9.50024V9.00024C14.9957 8.39143 14.8107 7.79767 14.4686 7.29399C14.6433 6.84161 14.7144 6.35583 14.6767 5.87236C14.6389 5.38889 14.4933 4.92003 14.2505 4.50024C13.7047 4.50012 13.1676 4.63747 12.6888 4.89962C12.21 5.16178 11.805 5.54029 11.5111 6.00024H9.48986Z" stroke="#353A3E" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M8.50049 16.9996V14.4996C8.50049 13.9692 8.7112 13.4605 9.08627 13.0854C9.46135 12.7103 9.97006 12.4996 10.5005 12.4996C11.0309 12.4996 11.5396 12.7103 11.9147 13.0854C12.2898 13.4605 12.5005 13.9692 12.5005 14.4996V16.9996" stroke="#353A3E" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M8.50034 15.4998H6.50034C5.9699 15.4998 5.4612 15.2891 5.08612 14.914C4.71105 14.5389 4.50034 14.0302 4.50034 13.4998C4.50034 12.9694 4.28962 12.4606 3.91455 12.0856" stroke="#353A3E" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M3 17.1146L3.37487 16.7837V16.7837L3 17.1146ZM18 17.1146L17.6251 16.7837V16.7837L18 17.1146ZM15 19.4327L15.2253 19.8791V19.8791L15 19.4327ZM6 19.4327L6.22531 18.9863V18.9863L6 19.4327ZM8.5 20.25L8.38796 20.7373C8.53639 20.7714 8.69228 20.736 8.81143 20.6412C8.93058 20.5463 9 20.4023 9 20.25H8.5ZM12.5 20.25H12C12 20.4023 12.0694 20.5463 12.1886 20.6412C12.3077 20.736 12.4636 20.7714 12.612 20.7373L12.5 20.25ZM0.5 10.5H1C1 5.25329 5.25329 1 10.5 1V0.5V0C4.70101 0 0 4.70101 0 10.5H0.5ZM10.5 0.5V1C15.7467 1 20 5.25329 20 10.5H20.5H21C21 4.70101 16.299 0 10.5 0V0.5ZM3 17.1146L3.37487 16.7837C1.89649 15.1087 1 12.9097 1 10.5H0.5H0C0 13.1626 0.991693 15.5948 2.62513 17.4454L3 17.1146ZM20.5 10.5H20C20 12.9097 19.1035 15.1087 17.6251 16.7837L18 17.1146L18.3749 17.4454C20.0083 15.5948 21 13.1626 21 10.5H20.5ZM18 17.1146L17.6251 16.7837C16.8274 17.6875 15.8607 18.4382 14.7747 18.9863L15 19.4327L15.2253 19.8791C16.4259 19.2731 17.4939 18.4436 18.3749 17.4454L18 17.1146ZM6 19.4327L6.22531 18.9863C5.13935 18.4382 4.17257 17.6875 3.37487 16.7837L3 17.1146L2.62513 17.4454C3.50611 18.4436 4.57411 19.2731 5.7747 19.8791L6 19.4327ZM8.5 20.25L8.61204 19.7627C7.82798 19.5824 6.87405 19.3138 6.22531 18.9863L6 19.4327L5.7747 19.8791C6.53812 20.2644 7.59238 20.5544 8.38796 20.7373L8.5 20.25ZM15 19.4327L14.7747 18.9863C14.126 19.3138 13.172 19.5824 12.388 19.7627L12.5 20.25L12.612 20.7373C13.4076 20.5544 14.4619 20.2644 15.2253 19.8791L15 19.4327ZM8.5 20.25H9V16.6146H8.5H8V20.25H8.5ZM12.5 20.25H13V16.6146H12.5H12V20.25H12.5Z" fill="#353A3E"/>
              </svg>
              GitHub
            </a>
          </div>
        </div><!-- /.lp-hero-bottom -->
      </div><!-- /.lp-hero-inner -->
    </section>

    <!-- ── Agents bar ───────────────────────────────── -->
    <section class="lp-usedby" aria-label="Supported agents">
      <div class="lp-usedby-inner">
        <span class="lp-usedby-label">TEST ANY COMBINATION - API · SKILLS · MCP · CLI WITH 20+ CODING AGENTS</span>
        <div class="lp-agents-track-wrap">
          <div class="lp-agents-fade lp-agents-fade-left"></div>
          <div class="lp-agents-track">
            <div class="lp-agents-list" aria-hidden="true">
              <div class="lp-agent-logo"><img src="/agents/claude.svg" class="lp-agent-icon" alt="">Claude Code</div>
              <div class="lp-agent-logo"><img src="/agents/codex.svg" class="lp-agent-icon" alt="">Codex</div>

              <div class="lp-agent-logo"><img src="/agents/gemini.svg" class="lp-agent-icon" alt="">Gemini</div>
              <div class="lp-agent-logo"><img src="/agents/kiro.png" class="lp-agent-icon" alt="">Kiro</div>
              <div class="lp-agent-logo"><img src="/agents/goose.svg" class="lp-agent-icon" alt="">Goose</div>
